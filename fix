#!/bin/sh

# Basisverzeichnisse
ROOT="src"
CORE_DIR="src/core"
OLD_DIR="src/old"

# Ordner anlegen
mkdir -p "$OLD_DIR"

# Dateien, die NICHT verschoben werden sollen
KEEP="
box42_init.c
box42.c
box42_strds.c
session.c
mail.c
config.c
sha256.c
hystack.c
main.c
CMakeLists.txt
"

should_keep() {
    for k in $KEEP; do
        if [ "$1" = "$k" ]; then
            return 0
        fi
    done
    return 1
}

echo "=== BOX42 Cleanup gestartet ==="

# 1) Core-Verzeichnis aufräumen
echo "→ Prüfe $CORE_DIR ..."
for f in "$CORE_DIR"/*; do
    filename=$(basename "$f")

    if should_keep "$filename"; then
        echo "   Behalte: $filename"
    else
        echo "   Verschiebe: $filename → $OLD_DIR/"
        mv "$f" "$OLD_DIR/"
    fi
done

# 2) Alle anderen src/* Ordner komplett verschieben
echo "→ Verschiebe alle anderen src/* Ordner nach $OLD_DIR ..."

for d in "$ROOT"/*; do
    base=$(basename "$d")

    case "$base" in
        core|old)
            echo "   Überspringe: $base/"
            ;;
        *)
            echo "   Verschiebe Ordner: $base/ → old/"
            mv "$d" "$OLD_DIR/"
            ;;
    esac
done

echo "=== Cleanup abgeschlossen ==="
