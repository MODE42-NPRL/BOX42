# BSDmakefile für BOX42

CC = cc
CFLAGS = -std=c99 -Wall -Wextra -O2

SRC_DIR = ../src
BUILD_DIR = ../build/obj
TARGET = box42

SRCS != find ${SRC_DIR} -name "*.c"
OBJS = ${SRCS:S,${SRC_DIR}/,${BUILD_DIR}/,S,.c,.o,}

all: ${BUILD_DIR} ${TARGET}

${BUILD_DIR}:
    mkdir -p ${BUILD_DIR}

${BUILD_DIR}/%.o: ${SRC_DIR}/%.c
    ${CC} ${CFLAGS} -c $< -o $@

${TARGET}: ${OBJS}
    ${CC} ${CFLAGS} ${OBJS} -o ${TARGET}

clean:
    rm -rf ${BUILD_DIR} ${TARGET}

.PHONY: all clean

