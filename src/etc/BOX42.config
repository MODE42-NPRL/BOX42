[tnc]
device = /dev/ttyUSB0 #tnc | baycom | pccom
baud = 9600
type = tnc
enabled = yes
kiss_port = 0
power_rtsdtr = no

[system]
motd = Welcome to BOX42.
prompt_chat = [chat]>
prompt_mail = [mail]>
prompt_box = [box]>
prompt_system = [system]>
prompt_idle = [idle]>

[sorting]
numeric_first = true
descending_dates = true

[nodes]
max_nodes = 64
node_default_name = Node
node_default_status = online

[login]
login_ok = Login successful.
login_fail = Invalid login.
registration_ok = Registration complete.
registration_fail = Registration failed.
userdata_guest = User: Guest
userdata_level = Level:
userdata_masked_password = Password: ********

[focus]
focus_chat = Focus: chat
focus_mail = Focus: mail
focus_box = Focus: box
focus_system = Focus: system
focus_idle = Focus: idle
focus_unknown = Unknown focus.

[sysinfo]
header = System Information:
arch = Architecture:
os = Operating System:
utc = UTC Date:
nodes = Nodes:
nodes_online = online
nodes_offline = offline
nodes_locked = locked
node_limit = Node limit:

[commands]
unknown_command = Unknown command.
need_focus = Not in a focus area. Use #focus <area>.
removeme_confirm = Confirmation required: #removeme true
removeme_guest = Guests cannot be removed.
removeme_done = Your account has been removed.

[chat]
join_ok = You joined the chat.
leave_ok = You left the chat.
say_prefix = 
who_header = Online users:

[mail]
mail_not_implemented = Mail system not implemented yet.

[box]
box_not_implemented = BOX system not implemented yet.

[system_engine]
access_denied = System access denied.
system_help_header = System commands:
system_help_users = users   - list users
system_help_stats = stats   - system stats
system_help_help = help    - this help
system_users = User listing not implemented yet.
system_stats = System stats not implemented yet.

[logging]
log_login_ok = LOGIN_OK
log_login_fail = LOGIN_FAIL
log_registration = REGISTRATION
log_focus_change = FOCUS_CHANGE
log_chat_say = CHAT_SAY
log_chat_join = CHAT_JOIN
log_chat_leave = CHAT_LEAVE
log_removeme = REMOVEME

[sqlite]
storage = sqlite
sqlite_mode = auto
sqlite_remote_host =
sqlite_remote_port =
