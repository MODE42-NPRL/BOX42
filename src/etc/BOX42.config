# ============================
#   BOX42 — STANDARD CONFIG
# ============================

# ---- System ----
box_name            "BOX42"
box_location        "Bad Mergentheim, DE"
prompt              ">"
UTCampm             "no"
motd_file           "motd.txt"
banner_color        cyan
log_level           info
max_sessions        32
max_channels        32
max_nodes           32

# ---- Networking ----
listen4             2323
listen6             2323
idle_timeout        900
flood_protect       on

# ---- Paths ----
db_path             "data/box42.db"
schema_users        "sqlite_schema-users.sql"
schema_mail         "sqlite_schema-mail.sql"
schema_files        "sqlite_schema-files.sql"
schema_config       "sqlite_schema-config.sql"

mail_store          "data/mail/"
file_store          "data/files/"
log_file            "logs/box42.log"

# ---- Users ----
owner_user          "akb"
owner_pass          "ownerpass"

admin_user          "sysop"
admin_pass          "adminpass"

guest_enabled       on
guest_name          "guest"
guest_home          "rooms/guest/"

# ---- Mail ----
mail_enabled        on
mail_max_size       65536
mail_max_boxes      256

# Extended options
mail_retention_days 30
mail_quota_user     1048576
mail_quota_admin    8388608
mail_sysbox_user    "sysop"
mail_allow_admin    on
mail_allow_user2user on
mail_index_cache    on
mail_flood_limit    10
mail_log_level      info

# ---- Files ----
files_enabled       on
files_max_size      1048576
files_allow_ul      on
files_allow_dl      on

# ---- Channels ----
default_room        1
room_path           "rooms/"
room_autocreate     off

# ---- AX.25 / TNC ----
tnc_enabled         on
tnc_device          "/dev/ttyUSB0"
tnc_baud            1200
tnc_kiss            on
ax25_callsign       "DB0BOX-1"
ax25_alias          "BOX42"
ax25_route          "ax25_routes.conf"

# ---- Security ----
password_hash       sha256
allow_localhost     on
allow_telnet        on
allow_ipv6          on
allow_ax25          on

# ---- Debug ----
debug_sql           off
debug_tnc           off
debug_sessions      off
